# Ajustes locales de Claude Code
.claude/

# Fotos originales sin optimizar: se quedan en tu equipo, NO en el repo.
# La web sirve las versiones .webp ligeras (fotos/foto-01.webp ...); subir los
# originales de varios MB llenaría el repositorio público de forma permanente.
fotos/foto-*.jpeg
fotos/foto-*.jpg
fotos/foto-*.JPG
fotos/IMG_*.JPG
fotos/IMG_*.jpg

# Vídeo original sin comprimir: solo va al repo la versión web ligera
# (video/video.mp4). El original de decenas de MB se queda en tu equipo.
video/*.mp4
!video/video.mp4

# Windows
Thumbs.db
desktop.ini

# macOS
.DS_Store
